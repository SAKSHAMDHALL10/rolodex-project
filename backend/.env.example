# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Database ---
# Must use the postgresql+psycopg:// scheme (psycopg3), not postgresql:// or
# postgres:// - Supabase/Render dashboards often hand out the latter by
# default. If your password contains special characters (@ # % / :), percent-
# encode it first (e.g. Python's urllib.parse.quote_plus(password)) - an
# un-encoded '@' is the most common cause of a "connection failed" error.
# Local Docker Compose Postgres (see docker-compose.yml):
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rolodex
# Supabase example:
# DATABASE_URL=postgresql+psycopg://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# --- Gemini (Google GenAI) ---
GEMINI_API_KEY=your-gemini-api-key-here
# Current GA production models as of July 2026. See
# https://ai.google.dev/gemini-api/docs/models for the current list if
# either of these is ever deprecated - just change the value here, no code
# change needed. The app validates both against the live API on startup and
# fails with a clear error (not an obscure runtime exception) if invalid.
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=1536

# --- CORS ---
# Comma-separated exact origins (a trailing slash is fine - it's stripped
# automatically). Example for production: CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000
# Optional: also allow origins matching a regex, e.g. Vercel preview URLs:
# CORS_ORIGIN_REGEX=https://your-app.*\.vercel\.app

# --- Duplicate detection ---
DUPLICATE_SIMILARITY_THRESHOLD=0.90
DUPLICATE_NAME_FUZZ_THRESHOLD=88

# URL of the FastAPI backend's versioned API prefix.
# Must be a FULL absolute URL: scheme (https://) + host + /api/v1 suffix.
# A bare domain (e.g. "your-backend.up.railway.app" with no scheme) is NOT
# valid here - fetch() would silently treat it as a relative path against
# the current page's origin instead of the backend, producing 404s. The
# frontend validates this at runtime and fails with a clear error if
# misconfigured.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
